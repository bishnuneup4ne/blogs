# Copy to .env.local for local dev (never commit .env.local)
# On Vercel: Project → Settings → Environment Variables — add the same keys (see DEPLOY.md)

# ── Supabase (required) ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public bucket for admin image uploads (create in Supabase → Storage → images, public)
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=images

# ── Admin panel ─────────────────────────────────────────────────────
# Password for /admin/login (sets httpOnly admin_auth cookie)
PAGE_ACCESS_PASSWORD=choose-a-strong-password

# ── Email (optional — newsletter broadcast from admin) ──────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=newsletter@yourdomain.com
