# See https://help.github.com/articles/ignoring-files/

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.pnp.*

# next.js
/.next/
/out/

# production
/build
/dist

# testing
/coverage

# misc
.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

