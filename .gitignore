.env
.env.*
!.env.example

# local binaries / installers
*.exe
*.msi
*.dmg

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / editor
.idea/
.vscode/*
!.vscode/extensions.json
.cursor/
*.swp
*.swo

# supabase local CLI
.supabase/

# scratch / local test files
test.js
test2.js

# OS / tooling
.agents/
